{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/calendar.ics", "destination": "/api/calendar" },
    { "source": "/api/calendar.ics", "destination": "/api/calendar" }
  ]
}
